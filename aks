variable "cluster_name" {}
variable "resource_group_name" {}
variable "host" {}
variable "client_certificate" {}
variable "client_key" {}
variable "cluster_ca_certificate" {}
variable "oidc_issuer_url" {}
variable "namespace" { default = "default" }
variable "service_account_name" {}

# 1. Configure the Kubernetes provider for THIS specific cluster instance
provider "kubernetes" {
  host                   = var.host
  client_certificate     = base64decode(var.client_certificate)
  client_key             = base64decode(var.client_key)
  cluster_ca_certificate = base64decode(var.cluster_ca_certificate)
}

# 2. Create the Azure Managed Identity
resource "azurerm_user_assigned_identity" "workload_id" {
  name                = "${var.cluster_name}-identity"
  location            = "East US" # Use your region
  resource_group_name = var.resource_group_name
}

# 3. Create the Kubernetes Service Account
resource "kubernetes_service_account" "sa" {
  metadata {
    name      = var.service_account_name
    namespace = var.namespace
    annotations = {
      "azure.workload.identity/client-id" = azurerm_user_assigned_identity.workload_id.client_id
    }
  }
}

# 4. Create the Federated Identity Credential
resource "azurerm_federated_identity_credential" "federated" {
  name                = "${var.cluster_name}-federated"
  resource_group_name = var.resource_group_name
  parent_id           = azurerm_user_assigned_identity.workload_id.id
  audience            = ["api://AzureADTokenExchange"]
  issuer              = var.oidc_issuer_url
  subject             = "system:serviceaccount:${var.namespace}:${var.service_account_name}"
}




data "azurerm_kubernetes_cluster" "clusters" {
  for_each            = toset(["cluster-a", "cluster-b"]) # Your cluster names
  name                = each.key
  resource_group_name = "your-resource-group"
}

module "aks_workload_identity" {
  source   = "./modules/workload-identity"
  for_each = data.azurerm_kubernetes_cluster.clusters

  cluster_name         = each.value.name
  resource_group_name  = each.value.resource_group_name
  oidc_issuer_url      = each.value.oidc_issuer_url
  service_account_name = "my-app-sa"

  # Pass credentials from the data source to the module's provider
  host                   = each.value.kube_config.0.host
  client_certificate     = each.value.kube_config.0.client_certificate
  client_key             = each.value.kube_config.0.client_key
  cluster_ca_certificate = each.value.kube_config.0.cluster_ca_certificate
}
